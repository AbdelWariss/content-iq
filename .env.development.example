# в”Ђв”Ђ Environnement de DГ‰VELOPPEMENT LOCAL в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Copier en `.env.development` (ou `.env`) pour le dev local.
# вљ пёЏ NE JAMAIS pointer sur la base de PRODUCTION en local.
# DГ©marrer Mongo + Redis localement : `docker-compose up -d mongodb redis`

NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:5173

# Bases LOCALES (jamais Atlas/Upstash en dev)
MONGODB_URI=mongodb://localhost:27017/contentiq
REDIS_URL=redis://localhost:6379

# Auth вЂ” secrets de dev (в‰Ө 32 caractГЁres), Г  ne pas rГ©utiliser en prod
JWT_ACCESS_SECRET=dev_access_secret_minimum_32_characters_xx
JWT_REFRESH_SECRET=dev_refresh_secret_minimum_32_characters_x
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Anthropic (requis вЂ” clГ© de dev)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-5

# Optionnels en dev (laisser vide в†’ fallbacks)
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
EMAIL_FROM=dev@contentiq.local

# Pour seeder une base PROD (DANGER) il faut explicitement : ALLOW_PROD_SEED=true
